{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "palette": {
    "deep": "#0d0f17",
    "fg": "#a9b1d6",
    "muted": "#787c99",
    "dim": "#5a5d8a",
    "surface": "#1e202e",
    "purple": "#a78bfa",
    "lilac": "#c4a8ff",
    "blue": "#7aa2f7",
    "sky": "#a4c0ff",
    "cyan": "#00d4ff",
    "ice": "#5ff0ff",
    "teal": "#73daca",
    "green": "#7ce38b",
    "mint": "#9eff9b",
    "yellow": "#ffd866",
    "gold": "#e0af68",
    "pink": "#ff6188",
    "rose": "#ff85a1",
    "orange": "#ff9e64"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "p:purple",
          "properties": {
            "macos": ""
          },
          "template": "{{ .Icon }} "
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "p:lilac",
          "template": "{{ .UserName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:cyan",
          "properties": {
            "style": "full",
            "folder_separator_icon": "/"
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (not .Working.Changed) (not .Staging.Changed) (gt .StashCount 0) }}p:gold{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "template": " {{ .HEAD }}{{ $s := \"\" }}{{ if gt .Ahead 0 }}{{ $s = printf \"%s↑%d \" $s .Ahead }}{{ end }}{{ if gt .Behind 0 }}{{ $s = printf \"%s↓%d \" $s .Behind }}{{ end }}{{ if .Staging.Changed }}{{ $s = printf \"%s+%d \" $s (add (add .Staging.Added .Staging.Modified) .Staging.Deleted) }}{{ end }}{{ if gt .Working.Modified 0 }}{{ $s = printf \"%s!%d \" $s .Working.Modified }}{{ end }}{{ if gt .Working.Untracked 0 }}{{ $s = printf \"%s?%d \" $s .Working.Untracked }}{{ end }}{{ if gt .StashCount 0 }}{{ $s = printf \"%s*%d \" $s .StashCount }}{{ end }}{{ if ne $s \"\" }} <p:purple><b>[{{ trim $s }}]</b></>{{ end }} "
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:gold",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": " {{ .Full }} "
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:gold",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": " {{ .Full }} "
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:gold",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": " {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "p:gold",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": " {{ .Full }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:dim",
          "properties": {
            "threshold": 100,
            "style": "round"
          },
          "template": " {{ .FormattedMs }}"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:pink{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "   {{ if eq .Code 0 }}{{ else }} {{ .Code }}{{ end }}"
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:muted",
          "properties": {
            "time_format": "15:04"
          },
          "template": "    {{ .CurrentDate | date .Format }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:pink{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "❯ "
        }
      ]
    }
  ]
}