{
  "claude_code_experimental_agent_teams": true,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "shopify-ai-toolkit@claude-plugins-official": true,
    "stripe@claude-plugins-official": false,
    "superpowers@superpowers-dev": true,
    "swift-lsp@claude-plugins-official": true
  },
  "env": {
    "_ZO_DOCTOR": "0"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "paper": {
      "source": {
        "repo": "paper-design/agent-plugins",
        "source": "github"
      }
    },
    "superpowers-dev": {
      "source": {
        "repo": "obra/superpowers",
        "source": "github"
      }
    },
    "understand-anything": {
      "source": {
        "repo": "Lum1104/Understand-Anything",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/juppy/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/Users/juppy/.go/bin/claudio",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__codegraph__codegraph_explore",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_status"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "bash /Users/juppy/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "custom:tokyo-nebula-andromeda",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}